# Supabase — get from Project Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Admin email — who gets access to /admin
VITE_ADMIN_EMAIL=owner@leaselens.au

# Anthropic — server-side only (set in Vercel dashboard, not here)
# For local dev only — never commit this
ANTHROPIC_API_KEY=sk-ant-your-key-here
